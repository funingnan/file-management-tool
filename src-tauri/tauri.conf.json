{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF知识库",
  "version": "0.1.9",
  "identifier": "com.pdf-knowledge-base.app",
  "build": {
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "PDF 知识库",
        "width": 1180,
        "height": 800,
        "minWidth": 1180,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
